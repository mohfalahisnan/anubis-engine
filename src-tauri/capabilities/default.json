{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Anubis OS — grants FS read/write/walk access to AppData, Documents, Desktop and Home directories.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-create",
    "fs:allow-remove",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-rename",
    "fs:allow-open",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:scope-appdata-recursive",
    "fs:scope-document-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-home-recursive"
  ]
}
